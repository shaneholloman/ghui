{
	"name": "@kitlangton/ghui",
	"version": "0.1.9",
	"description": "Terminal UI for GitHub pull requests",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitlangton/ghui.git"
	},
	"bugs": {
		"url": "https://github.com/kitlangton/ghui/issues"
	},
	"homepage": "https://github.com/kitlangton/ghui#readme",
	"keywords": [
		"github",
		"pull-requests",
		"terminal",
		"tui",
		"bun"
	],
	"files": [
		"bin",
		"src",
		"README.md",
		".env.example",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/"
	},
	"bin": {
		"ghui": "bin/ghui.js"
	},
	"scripts": {
		"dev": "bun --watch src/index.tsx",
		"start": "bun run src/index.tsx",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@effect/atom-react": "4.0.0-beta.47",
		"@opentui/core": "0.1.97",
		"@opentui/react": "0.1.97",
		"effect": "4.0.0-beta.47",
		"react": "19.2.5",
		"scheduler": "0.27.0"
	},
	"devDependencies": {
		"@types/bun": "1.3.12",
		"@types/react": "19.2.14",
		"typescript": "6.0.2"
	}
}
