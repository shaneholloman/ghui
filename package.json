{
	"name": "@kitlangton/ghui",
	"version": "0.7.1",
	"description": "Terminal UI for GitHub pull requests",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitlangton/ghui.git"
	},
	"bugs": {
		"url": "https://github.com/kitlangton/ghui/issues"
	},
	"homepage": "https://github.com/kitlangton/ghui#readme",
	"keywords": [
		"github",
		"pull-requests",
		"terminal",
		"tui",
		"bun"
	],
	"files": [
		"bin",
		"dist",
		"README.md",
		".env.example",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/"
	},
	"bin": {
		"ghui": "bin/ghui.js"
	},
	"scripts": {
		"build:cli": "bun run dev/build-cli.ts",
		"build:npm-packages": "bun run dev/build-npm-packages.ts",
		"build:standalone": "bun run dev/build-standalone.ts",
		"changeset": "npm exec --package @changesets/cli@2.31.0 -- changeset",
		"changeset:status": "npm exec --package @changesets/cli@2.31.0 -- changeset status",
		"changeset:version": "npm exec --package @changesets/cli@2.31.0 -- changeset version",
		"dev": "GHUI_MOTEL_PORT=${GHUI_MOTEL_PORT:-27686} bun --watch src/index.tsx",
		"dev:logo": "bun --watch dev/loadingLogo.tsx",
		"dev:mock": "GHUI_MOCK_PR_COUNT=200 GHUI_MOCK_REPO_COUNT=4 bun --watch src/index.tsx",
		"dev:mock:repo": "GHUI_MOCK_PR_COUNT=200 GHUI_MOCK_REPO_COUNT=4 GHUI_MOCK_REPOSITORY=anomalyco/opencode bun --watch src/index.tsx",
		"fixtures:opencode": "bun run dev/fetch-opencode-fixtures.ts",
		"start": "bun run src/index.tsx",
		"start:mock": "GHUI_MOCK_PR_COUNT=400 GHUI_MOCK_REPO_COUNT=4 bun run src/index.tsx",
		"start:mock:repo": "GHUI_MOCK_PR_COUNT=200 GHUI_MOCK_REPO_COUNT=4 GHUI_MOCK_REPOSITORY=anomalyco/opencode bun run src/index.tsx",
		"test": "bun test test",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --tsconfig tsconfig.json src/ test/",
		"format": "oxfmt src/ test/ dev/",
		"format:check": "oxfmt --check src/ test/ dev/",
		"package:smoke": "bun run dev/package-smoke.ts",
		"prepublishOnly": "printf '%s\n' 'Publish dist/npm/main, not the source checkout.' && exit 1",
		"prepack": "bun run build:cli"
	},
	"workspaces": [
		".",
		"packages/*"
	],
	"dependencies": {
		"@effect/atom-react": "4.0.0-beta.59",
		"@effect/sql-sqlite-bun": "4.0.0-beta.59",
		"@opentui/core": "0.2.1",
		"@opentui/react": "0.2.1",
		"effect": "4.0.0-beta.59",
		"react": "19.2.5",
		"scheduler": "0.27.0"
	},
	"devDependencies": {
		"@ghui/keymap": "workspace:*",
		"@effect/language-service": "0.85.1",
		"@types/bun": "1.3.12",
		"@types/react": "19.2.14",
		"oxfmt": "0.47.0",
		"oxlint": "1.62.0",
		"typescript": "6.0.2"
	}
}
